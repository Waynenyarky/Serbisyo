# Change API_BASE_URL to match your backend (no trailing slash).
# Examples:
#   Same machine (Windows):  http://localhost:3000
#   Android emulator:        http://10.0.2.2:3000
#   Device on same network:  http://YOUR_PC_IP:3000
API_BASE_URL=http://localhost:3000

# Google OAuth Web client ID (required for native Google Sign-In idToken on mobile)
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
