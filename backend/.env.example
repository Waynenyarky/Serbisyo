# Copy to .env and set your values
# Change PORT to run the API on a different port (default 3000)
PORT=3000
MONGODB_URI=mongodb://localhost:27017/serbisyo
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google OAuth (backend) — replace placeholders with your values
GOOGLE_CLIENT_ID=your-backend-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-backend-client-secret